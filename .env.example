# =============================================================================
# NocoDB - Environment Configuration
# =============================================================================
# Documentation: https://docs.nocodb.com/getting-started/self-hosted/environment-variables/
# =============================================================================

# -----------------------------------------------------------------------------
# Stack Configuration
# -----------------------------------------------------------------------------

# Unique stack name (used for container names, volumes, networks)
STACK_NAME=db_example_app_domain_com

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TIME_ZONE=Etc/UTC

# =============================================================================
# Image Configuration
# =============================================================================

# +-------------------------------------------------------------------------+
# | PRODUCTION (docker-compose.local.yml, docker-compose.traefik*.yml)      |
# +-------------------------------------------------------------------------+
# | Nutzt fertige BAUER GROUP Images aus GHCR.                              |
# | Verwendet: NOCODB_IMAGE, NOCODB_VERSION, NOCODB_INIT_*, NOCODB_BACKUP_* |
# +-------------------------------------------------------------------------+
#
# -----------------------------------------------------------------------------
# Production Images
# -----------------------------------------------------------------------------
# BAUER GROUP Images für Production Deployments.
# für docker-compose.local.yml und docker-compose.traefik*.yml.

# NocoDB Server Image
NOCODB_IMAGE=ghcr.io/bauer-group/cs-nocodb/nocodb
NOCODB_VERSION=latest

# Init Container Image (Database Maintenance Tasks)
NOCODB_INIT_IMAGE=ghcr.io/bauer-group/cs-nocodb/nocodb-init
NOCODB_INIT_VERSION=latest

# Backup Sidecar Image (Automated Backups)
NOCODB_BACKUP_IMAGE=ghcr.io/bauer-group/cs-nocodb/nocodb-backup
NOCODB_BACKUP_VERSION=latest

# +-------------------------------------------------------------------------+
# | DEVELOPMENT (docker-compose.development.yml)                            |
# +-------------------------------------------------------------------------+
# | Baut lokale Images aus src/ mit offiziellen NocoDB Images als Basis.    |
# | Verwendet: BASE_NOCODB_IMAGE, BASE_NOCODB_VERSION                       |
# +-------------------------------------------------------------------------+
#
# -----------------------------------------------------------------------------
# Build Images (Development)
# -----------------------------------------------------------------------------
# Offizielle NocoDB Images als Basis für lokale Docker Builds.
# Nur für docker-compose.development.yml relevant.

# NocoDB Base Image (offiziell)
BASE_NOCODB_IMAGE=nocodb/nocodb
BASE_NOCODB_VERSION=latest

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# PostgreSQL password (REQUIRED - change this!)
# Generate: openssl rand -base64 16
DATABASE_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# PostgreSQL version (optional, default: 18)
# POSTGRES_VERSION=18

# -----------------------------------------------------------------------------
# Application Secrets
# -----------------------------------------------------------------------------
# Beide Werte MUESSEN auf allen Instanzen identisch sein (Cluster-Stack) und
# gehoeren in den Secret-Store, nicht nur in diese Datei.

# JWT-Signaturschluessel.
# Ohne Vorgabe generiert NocoDB beim ersten Start eine uuidv4 und legt sie in
# der Tabelle nc_store ab. Das funktioniert - aber ein Restore oder eine
# Migration ohne diese Tabelle invalidiert dann saemtliche Sessions.
#
# BESTANDSINSTALLATION: NICHT neu generieren! Den vorhandenen Wert uebernehmen,
# sonst werden alle Benutzer sofort ausgeloggt:
#   SELECT value FROM nc_store WHERE key ILIKE '%jwt%';
# NEUINSTALLATION: openssl rand -hex 32
NC_AUTH_JWT_SECRET=CHANGE_ME_JWT_SECRET

# Gueltigkeitsdauer der Access-Token.
# NocoDB-Default waere 10h - hier bewusst 12h, damit ein Arbeitstag inklusive
# Rand nicht durch einen Re-Login unterbrochen wird.
NC_JWT_EXPIRES_IN=12h

# -----------------------------------------------------------------------------
# NC_CONNECTION_ENCRYPT_KEY - bewusst NICHT gesetzt (Opt-in)
# -----------------------------------------------------------------------------
# Verschluesselt die Zugangsdaten EXTERNER Datenquellen (Tabelle "sources").
# Ohne Key liegen diese Credentials im Klartext in der Datenbank - und damit in
# jedem pg_dump und jedem Backup-Ziel.
#
# Warum trotzdem standardmaessig aus: Das Aktivieren ist IRREVERSIBEL und
# race-anfaellig. Der Nutzen ist null, solange keine externen Datenquellen
# angelegt sind - das Risiko dagegen sofort real. Deshalb bewusst als Opt-in.
#
# Ein leerer Wert ist sicher, nicht etwa "mit leerem Schluessel verschluesselt":
#   initDataSourceEncryption.ts:  if (!process.env.NC_CONNECTION_ENCRYPT_KEY) return;
# Leerer String ist in JavaScript falsy, die Migration wird uebersprungen.
#
# NIEMALS einen Platzhalter wie "CHANGE_ME_..." eintragen: das waere schlechter
# als gar kein Key, weil die Credentials dann mit einem oeffentlich bekannten
# Wert verschluesselt sind und die irreversible Migration trotzdem laeuft.
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ AKTIVIEREN - nur in dieser Reihenfolge                                      │
# ├─────────────────────────────────────────────────────────────────────────────┤
# │ 1. Pruefen, ob es ueberhaupt externe Datenquellen gibt:                     │
# │      SELECT id, alias, type FROM sources;                                   │
# │    Ist das Ergebnis leer, bringt der Key aktuell nichts.                    │
# │ 2. Gezielt sichern:  pg_dump -t sources -t bases                            │
# │    Das ist die EINZIGE Rueckfallebene.                                      │
# │ 3. Stack auf GENAU EINE Instanz reduzieren.                                 │
# │    Beim Cluster-Stack: nur nocodb-server-1 starten. Laufen mehrere Instanzen│
# │    parallel, versuchen mehrere die Re-Encrypt-Migration gleichzeitig -      │
# │    Doppelverschluesselung zerstoert die Credentials.                        │
# │ 4. Key setzen (openssl rand -hex 32), Instanz starten, Logs bis zum         │
# │    Abschluss der Migration beobachten.                                      │
# │ 5. JEDE externe Datenquelle einzeln oeffnen und die Verbindung bestaetigen. │
# │ 6. Erst dann hochskalieren.                                                 │
# │ 7. Key in den Secret-Store - und als NICHT rotierbar behandeln: jede        │
# │    spaetere Aenderung ODER Entfernung macht alle Credentials unlesbar.      │
# └─────────────────────────────────────────────────────────────────────────────┘
#
# NC_CONNECTION_ENCRYPT_KEY=

# Oeffentliche URL der Instanz. Ohne diesen Wert enthalten Einladungs-,
# Freigabe- und Passwort-Reset-Mails falsche Links.
# NC_SITE_URL=https://db.example.app.domain.com

# -----------------------------------------------------------------------------
# HINWEIS: "Invite Only Signup" ist KEINE Umgebungsvariable
# -----------------------------------------------------------------------------
# Ein frueher hier und in den Compose-Dateien gesetztes NC_INVITE_ONLY_SIGNUP
# wird von NocoDB nirgends gelesen (0 Treffer im Quelltext) und war damit
# wirkungslos - die Registrierung stand trotz der Einstellung offen.
#
# Der reale Schalter ist das Flag invite_only_signup in der Tabelle nc_store.
# Default: false (= offene Registrierung). Setzbar ausschliesslich ueber die
# Super-Admin-UI (Account Settings) oder die App-Settings-API.
# -> Nach jeder Neuinstallation aktiv pruefen und setzen.

# -----------------------------------------------------------------------------
# Connection Pool Settings
# -----------------------------------------------------------------------------
# NocoDB und PostgreSQL haben separate Pool-Einstellungen.
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ VERBINDUNGS-ARCHITEKTUR                                                     │
# ├─────────────────────────────────────────────────────────────────────────────┤
# │                                                                             │
# │  NocoDB App ─────► Knex.js Pool ─────► PostgreSQL                           │
# │                    (NC_DB_POOL_MAX)    (DATABASE_POOLMAXSIZE)               │
# │                                                                             │
# │  Formel: DATABASE_POOLMAXSIZE = NC_DB_POOL_MAX + 20%                        │
# │          (Reserve für Admin, Backups, Monitoring)                           │
# │                                                                             │
# └─────────────────────────────────────────────────────────────────────────────┘
#
# ┌─────────────────────────────┬───────┬───────┬───────┬───────────────────┐
# │ Einstellung                 │ Klein │Mittel │ Prod  │ Hochlast (Burst)  │
# │                             │ (Dev) │ 5-20U │ 20+U  │ 1000+ parallel    │
# ├─────────────────────────────┼───────┼───────┼───────┼───────────────────┤
# │ NC_DB_POOL_MAX              │ 10    │ 25    │ 50    │ 80                │
# │ DATABASE_POOLMAXSIZE        │ 12    │ 30    │ 60    │ 120               │
# │ Headroom-Faktor             │ +20%  │ +20%  │ +20%  │ +50%              │
# └─────────────────────────────┴───────┴───────┴───────┴───────────────────┘
#
# NC_DB_POOL_MAX: NocoDB Knex.js/tarn Pool (default: 10)
# Quelle: packages/nocodb/src/utils/nc-config/constants.ts
#         pool: { min: 0, max: +process.env.NC_DB_POOL_MAX || 10 }
#
# ACHTUNG - historischer Fehler: Bis einschliesslich v0.7.4 setzten die
# Compose-Dateien hier DB_MAX_POOL_SIZE. Diese Variable existiert in NocoDB
# NICHT (0 Treffer im Quelltext); der Pool lag faktisch immer beim Default 10,
# unabhaengig vom hier eingetragenen Wert. Die frueher zitierte Quelle
# https://github.com/nocodb/nocodb/pull/9974 wurde nie gemergt - damit gibt es
# auch keine Begrenzung auf 1..100, der Wert wird ungeprueft uebernommen.
#
# Es gibt KEINE Validierung und KEINE Warnung im Log:
#   NC_DB_POOL_MAX=0 oder ein Tippfehler -> NaN -> falsy -> stiller Default 10.
# Nach jeder Aenderung gegenpruefen:
#   SELECT state, count(*) FROM pg_stat_activity WHERE datname='nocodb'
#   GROUP BY 1;
#
# Hochlast-Profil (1000+ parallele Inserts via REST-API, 16GB+ RAM):
# - 80 App-Connections (Knex Pool)
# - 40 Reserve fuer Init/Backup/Admin/PG-System
# - = 120 PostgreSQL max_connections (50% Headroom statt 20%)
# - Begruendung: Bei 1000 parallelen Inserts queuen 920 in Knex's tarn.js;
#   groesserer Pool = kuerzere Queue = weniger acquireTimeout-Risiko.
#
# HINWEIS Multi-Instanz: Fuer docker-compose.cluster.yml gilt diese Tabelle
# NICHT. Dort ist NC_DB_POOL_MAX ein PRO-INSTANZ-Wert und muss dem HAProxy-
# maxconn entsprechen (8 Instanzen x 10 = 80 gleichzeitige Requests).

# NocoDB Connection Pool (Hochlast-Profil, Single-Instance)
NC_DB_POOL_MAX=80

# PostgreSQL max_connections (50% Headroom fuer Burst-Last)
DATABASE_POOLMAXSIZE=180

# -----------------------------------------------------------------------------
# Cluster-Stack (docker-compose.cluster*.yml)
# -----------------------------------------------------------------------------
# Nur relevant fuer den Mehr-Instanz-Betrieb. Der Single-Instance-Stack
# ignoriert diese Variablen vollstaendig.
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ WARUM UEBERHAUPT MEHRERE INSTANZEN                                          │
# ├─────────────────────────────────────────────────────────────────────────────┤
# │ NocoDB ist ein einzelner Node-Prozess und damit single-threaded. Eine        │
# │ Instanz nutzt genau EINEN CPU-Core - auf einem 24-Core-Host bleiben 23       │
# │ ungenutzt. Es gibt keinen Cluster-Mode; mehr Durchsatz gibt es nur ueber     │
# │ mehr Container.                                                             │
# └─────────────────────────────────────────────────────────────────────────────┘
#
# Pro Instanz, NICHT global. Wird auch an den HAProxy durchgereicht und dort
# als "maxconn" je Backend-Server verwendet - beide Werte koennen damit
# strukturell nicht auseinanderlaufen.
#
#   8 Instanzen x 10 = 80 gleichzeitige DB-gebundene Requests.
#
# Warum nicht hoeher: PostgreSQL degradiert jenseits von etwa 2-4x CPU-Cores an
# AKTIVEN Verbindungen (Lock-Contention, Context-Switching). Bei 24 Cores liegt
# das Optimum bei 50-100. Ein groesserer Pool je Instanz macht die Datenbank
# langsamer, nicht schneller. Ueberlast gehoert VOR die Datenbank in eine
# sichtbare Queue (HAProxy, mit 30s-Timeout), nicht hinein (Knex, 10 Minuten).
#
# WICHTIG - der Pool ist NICHT der Durchsatz-Engpass: Im Lasttest steht NocoDB
# unter Last bei ~105% CPU (ein Kern voll), PostgreSQL bei ~11%. Der Engpass ist
# der einzelne JavaScript-Thread je Instanz, nicht der Pool und nicht die DB.
# Der Sprung von Pool 10 auf 80 brachte im Single-Instance-Betrieb nur +9%.
# Wirklich mehr Durchsatz bringen nur MEHR INSTANZEN (mehr JS-Threads) und -
# wo der Client es kann - BULK-Inserts (Array statt Einzelsatz, ~11x).
# Fuer insert-lastige Lasten kann 20-25 statt 10 helfen (mehr Saetze
# gleichzeitig in Bearbeitung) - an der eigenen Last messen.
# NC_DB_POOL_MAX_CLUSTER -> wird im Budget-Block oben je Skalierungsstufe gesetzt

# PostgreSQL max_connections im Cluster:
#    80 (8 Instanzen x NC_DB_POOL_MAX_CLUSTER)
#  + 80 (Per-Source-Pools, gleichzeitig aktiv)
#  +  4 (nocodb-init)  +  4 (nocodb-backup)  +  6 (Admin/psql/Monitoring)
#  +  3 (superuser_reserved_connections)     + 23 (Marge)
#  = 200
#
# Autovacuum- und Parallel-Worker zaehlen NICHT dagegen:
#   MaxBackends = max_connections + autovacuum_max_workers
#               + max_worker_processes + max_wal_senders + 1
# DATABASE_POOLMAXSIZE_CLUSTER -> wird im Budget-Block oben je Skalierungsstufe gesetzt

# Dasselbe fuer die Entwicklungsumgebung (dort nur 2 Instanzen).
DATABASE_POOLMAXSIZE_CLUSTER_DEV=100

# =============================================================================
# RESSOURCENBUDGET DES CLUSTER-STACKS
# =============================================================================
# Ziel: Der Stack belegt nur einen definierten Teil des Hosts, auch wenn dieser
# deutlich mehr hat - damit weitere Stacks daneben laufen koennen.
#
# WICHTIG - was Compose NICHT kann: Es gibt keine Rechenoperationen in der
# Interpolation. Ein einzelnes "Gesamtbudget" laesst sich also nicht automatisch
# auf die Container aufteilen. Das Budget entsteht ausschliesslich als SUMME der
# Einzellimits. Deshalb unten drei vollstaendig durchgerechnete Stufen statt
# einer Formel, die es nicht gibt.
#
# Nachrechnen laesst sich die Summe jederzeit:
#   docker compose -f docker-compose.cluster.yml config | grep -E "cpus:|memory:"
#
# ALLE Werte sind CEILINGS, keine Reservierungen. Gemessener Leerlaufbedarf:
#   NocoDB ~715 MB je Instanz, Redis ~6 MB, HAProxy ~22 MB.
# Das Budget begrenzt also den Worst Case, nicht den Normalbetrieb.
#
# -----------------------------------------------------------------------------
# SKALIERUNGSSTUFE WAEHLEN
# -----------------------------------------------------------------------------
# Die Instanzzahl wird ueber Compose-Profile gesteuert. Entweder hier in der
# .env (empfohlen, gilt dann fuer jeden Aufruf) ...
#
#   COMPOSE_PROFILES=            ->  4 Instanzen   (Stufe S)
#   COMPOSE_PROFILES=scale6      ->  6 Instanzen   (Stufe M)
#   COMPOSE_PROFILES=scale8      ->  8 Instanzen   (Stufe L)
#
# ... oder pro Aufruf auf der Kommandozeile:
#   docker compose -f docker-compose.cluster.yml --profile scale8 up -d
#
# Mehrere Profile werden mit Komma kombiniert, z. B. mit dem Backup-Sidecar:
#   COMPOSE_PROFILES=scale8,backup
#
# ACHTUNG: Das Profil allein aendert nur die ANZAHL der Instanzen. Die Limits
# darunter muessen zur gewaehlten Stufe passen - sonst sprengt der Stack sein
# Budget. Deshalb steht unten je Stufe ein vollstaendiger, kopierbarer Block.
COMPOSE_PROFILES=

# =============================================================================
# STUFE S  -  4 Instanzen  -  Budget 16 GB / 16 Cores
# =============================================================================
# +----------------------+----------+-----------+------------------------------+
# | Komponente           |   Cores  |    RAM    |                              |
# +----------------------+----------+-----------+------------------------------+
# | 4x NocoDB            |  4 x 2.0 |  4 x 2G   | = 8.0 Cores / 8.0 GB         |
# | PostgreSQL           |      4.0 |     5G    | shared_buffers 1500MB        |
# | Redis                |      1.0 |   1500M   | maxmemory 1gb                |
# | HAProxy              |      1.0 |    256M   |                              |
# | Init (nur beim Start)|      1.0 |    512M   | beendet sich nach dem Lauf   |
# +----------------------+----------+-----------+------------------------------+
# | SUMME                |     15.0 |  15.21 GB | passt in 16 GB / 16 Cores    |
# +----------------------+----------+-----------+------------------------------+
#
# DB-Verbindungen: 4 Instanzen x 10 (Pool) x 2 (Per-Source) = 80, plus Reserve
# fuer Init, Backup, Admin und superuser_reserved -> 120 reichen.
#
# --- Aktive Werte fuer Stufe S -----------------------------------------------
NOCODB_CPU_LIMIT=2.0
NOCODB_MEMORY_LIMIT=2G
NC_DB_POOL_MAX_CLUSTER=10
VIPS_CONCURRENCY=2

POSTGRES_CPU_LIMIT=4.0
POSTGRES_MEMORY_LIMIT=5G
PG_SHARED_BUFFERS_CLUSTER=1500MB
PG_EFFECTIVE_CACHE_SIZE_CLUSTER=4GB
PG_WORK_MEM_CLUSTER=8MB
PG_MAINTENANCE_WORK_MEM_CLUSTER=256MB
DATABASE_POOLMAXSIZE_CLUSTER=120

REDIS_CPU_LIMIT=1.0
REDIS_MEMORY_LIMIT=1500M
REDIS_MEMORYLIMIT=1gb

HAPROXY_CPU_LIMIT=1.0
HAPROXY_MEMORY_LIMIT=256M
HAPROXY_WS_MAXCONN=500

# =============================================================================
# STUFE M  -  6 Instanzen  -  Budget 24 GB / 20 Cores
# =============================================================================
# +----------------------+----------+-----------+------------------------------+
# | 6x NocoDB            |  6 x 2.0 |  6 x 2G   | = 12.0 Cores / 12.0 GB       |
# | PostgreSQL           |      5.0 |     6G    | shared_buffers 2GB           |
# | Redis                |      1.0 |     2G    | maxmemory 1gb                |
# | HAProxy              |      1.0 |    512M   |                              |
# | Init                 |      1.0 |    512M   |                              |
# +----------------------+----------+-----------+------------------------------+
# | SUMME                |     20.0 |  21.00 GB | passt in 24 GB / 20 Cores    |
# +----------------------+----------+-----------+------------------------------+
#
# DB-Verbindungen: 6 x 10 x 2 = 120, plus Reserve -> 160.
#
# --- Werte fuer Stufe M (die obigen ersetzen) --------------------------------
#   COMPOSE_PROFILES=scale6
#
#   NOCODB_CPU_LIMIT=2.0
#   NOCODB_MEMORY_LIMIT=2G
#   NC_DB_POOL_MAX_CLUSTER=10
#   VIPS_CONCURRENCY=2
#
#   POSTGRES_CPU_LIMIT=5.0
#   POSTGRES_MEMORY_LIMIT=6G
#   PG_SHARED_BUFFERS_CLUSTER=2GB
#   PG_EFFECTIVE_CACHE_SIZE_CLUSTER=5GB
#   PG_WORK_MEM_CLUSTER=8MB
#   PG_MAINTENANCE_WORK_MEM_CLUSTER=384MB
#   DATABASE_POOLMAXSIZE_CLUSTER=160
#
#   REDIS_CPU_LIMIT=1.0
#   REDIS_MEMORY_LIMIT=2G
#   REDIS_MEMORYLIMIT=1gb
#
#   HAPROXY_CPU_LIMIT=1.0
#   HAPROXY_MEMORY_LIMIT=512M
#   HAPROXY_WS_MAXCONN=500

# =============================================================================
# STUFE L  -  8 Instanzen  -  Budget 32 GB / 24 Cores
# =============================================================================
# +----------------------+----------+-----------+------------------------------+
# | 8x NocoDB            |  8 x 2.0 |  8 x 2.5G | = 16.0 Cores / 20.0 GB       |
# | PostgreSQL           |      4.0 |     6G    | shared_buffers 2GB           |
# | Redis                |      1.0 |     3G    | maxmemory 2gb                |
# | HAProxy              |      1.0 |    512M   |                              |
# | Init                 |      1.0 |    512M   |                              |
# +----------------------+----------+-----------+------------------------------+
# | SUMME                |     23.0 |  30.00 GB | passt in 32 GB / 24 Cores    |
# +----------------------+----------+-----------+------------------------------+
#
# DB-Verbindungen: 8 x 10 x 2 = 160, plus Reserve -> 200.
#
# --- Werte fuer Stufe L (die obigen ersetzen) --------------------------------
#   COMPOSE_PROFILES=scale8
#
#   NOCODB_CPU_LIMIT=2.0
#   NOCODB_MEMORY_LIMIT=2560M
#   NC_DB_POOL_MAX_CLUSTER=10
#   VIPS_CONCURRENCY=2
#
#   POSTGRES_CPU_LIMIT=4.0
#   POSTGRES_MEMORY_LIMIT=6G
#   PG_SHARED_BUFFERS_CLUSTER=2GB
#   PG_EFFECTIVE_CACHE_SIZE_CLUSTER=6GB
#   PG_WORK_MEM_CLUSTER=8MB
#   PG_MAINTENANCE_WORK_MEM_CLUSTER=512MB
#   DATABASE_POOLMAXSIZE_CLUSTER=200
#
#   REDIS_CPU_LIMIT=1.0
#   REDIS_MEMORY_LIMIT=3G
#   REDIS_MEMORYLIMIT=2gb
#
#   HAPROXY_CPU_LIMIT=1.0
#   HAPROXY_MEMORY_LIMIT=512M
#   HAPROXY_WS_MAXCONN=500

# =============================================================================
# WAS BEIM AENDERN ZUSAMMENHAENGT
# =============================================================================
# Diese Groessen sind NICHT unabhaengig voneinander. Wer eine anfasst, muss die
# gekoppelten mitziehen - sonst kippt der Stack an einer anderen Stelle.
#
# +---------------------------+------------------------------------------------+
# | Wenn du aenderst ...      | ... dann zwingend mitziehen                     |
# +---------------------------+------------------------------------------------+
# | COMPOSE_PROFILES          | DATABASE_POOLMAXSIZE_CLUSTER                    |
# | (Instanzzahl)             | POSTGRES_MEMORY_LIMIT                           |
# |                           | Gesamtsumme gegen das Host-Budget pruefen       |
# +---------------------------+------------------------------------------------+
# | NC_DB_POOL_MAX_CLUSTER    | DATABASE_POOLMAXSIZE_CLUSTER                    |
# |                           | (Der Wert ist zugleich HAProxys maxconn je      |
# |                           |  Server - beide speist dieselbe Variable.)      |
# +---------------------------+------------------------------------------------+
# | POSTGRES_MEMORY_LIMIT     | PG_SHARED_BUFFERS_CLUSTER                       |
# |                           | PG_WORK_MEM_CLUSTER                             |
# |                           | DATABASE_POOLMAXSIZE_CLUSTER                    |
# +---------------------------+------------------------------------------------+
# | REDIS_MEMORYLIMIT         | REDIS_MEMORY_LIMIT (Container, ~1,5x maxmemory) |
# +---------------------------+------------------------------------------------+
# | NOCODB_CPU_LIMIT          | VIPS_CONCURRENCY (gleicher Wert)                |
# +---------------------------+------------------------------------------------+
#
# PostgreSQL - die haeufigste Fehlerquelle:
#   shared_buffers ist nur der EINE Teil. work_mem gilt JE Sortier- oder
#   Hash-Operation und JE Verbindung. Im schlechtesten Fall gilt also
#     shared_buffers + (max_connections x work_mem) + Overhead <= Container-Limit
#   Beispiel Stufe S: 1500MB + (120 x 8MB = 960MB) + ~500MB Overhead = ~3 GB,
#   passt in 5G. Wer work_mem auf 16MB verdoppelt, braucht dort ~4 GB.
#   Wird das Limit gerissen, killt der Kernel den Container - nicht PostgreSQL
#   selbst, das wuerde nur eine Query abbrechen.
#
# Redis:
#   maxmemory (REDIS_MEMORYLIMIT) begrenzt nur die NUTZDATEN. Hinzu kommen
#   Fragmentierung, AOF-Puffer und beim Snapshot-Fork Copy-on-Write - im
#   Extremfall nochmal die gleiche Menge. Deshalb Container-Limit ~1,5x.
#   Wichtig wegen maxmemory-policy=noeviction: ist maxmemory erreicht, scheitern
#   SCHREIBZUGRIFFE laut. Das ist gewollt (siehe Redis-Abschnitt weiter unten),
#   heisst aber: lieber grosszuegig dimensionieren.
#
# HAProxy:
#   Braucht praktisch nichts (gemessen ~22 MB). HAPROXY_WS_MAXCONN begrenzt
#   WebSocket-Verbindungen je Instanz und ist NICHT an den DB-Pool gekoppelt -
#   socket.io ist ueberwiegend idle und nicht DB-gebunden.

# -----------------------------------------------------------------------------
# Ressourcenlimits je NocoDB-Instanz
# -----------------------------------------------------------------------------
# Beides sind Ceilings, KEINE Reservierungen - ein Container belegt nur, was er
# tatsaechlich braucht (gemessen im Leerlauf: rund 715 MB, ~0,05 Cores).
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ MEMORY_LIMIT: klarer Nutzen, gemessen                                       │
# ├─────────────────────────────────────────────────────────────────────────────┤
# │ Node liest das cgroup-Limit und leitet daraus seine Heap-Groesse ab:        │
# │   mit 3G Limit  -> heap_size_limit 1728 MB                                  │
# │   ohne Limit    -> heap_size_limit richtet sich nach dem HOST-RAM           │
# │ Ohne Limit dimensionieren also alle 8 Instanzen gegen denselben Host-RAM    │
# │ und fordern zusammen ein Vielfaches dessen an, was vorhanden ist. Unter     │
# │ Druck wuerde der Kernel-OOM-Killer zuschlagen - moeglicherweise auf         │
# │ PostgreSQL. Mit Limit trifft es nur die eine Instanz, die dann neu startet. │
# └─────────────────────────────────────────────────────────────────────────────┘
# NOCODB_MEMORY_LIMIT -> wird im Budget-Block oben je Skalierungsstufe gesetzt

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ CPU_LIMIT: schwaecherer Nutzen - bewusst so belassen                        │
# ├─────────────────────────────────────────────────────────────────────────────┤
# │ NocoDBs JavaScript laeuft single-threaded, der Prozess hat aber rund 11     │
# │ Threads (libuv-Threadpool fuer Datei-I/O, V8-GC). Bei 8 x 2.0 = 16 auf 24   │
# │ Cores greift das Limit im Normalbetrieb NIE - es ist reine Schadensbegren-  │
# │ zung fuer den Fall, dass eine Instanz entgleist.                            │
# │                                                                             │
# │ Es loest insbesondere NICHT das Thread-Problem bei der Bildverarbeitung -   │
# │ dafuer ist VIPS_CONCURRENCY zustaendig (siehe unten).                        │
# └─────────────────────────────────────────────────────────────────────────────┘
# NOCODB_CPU_LIMIT -> wird im Budget-Block oben je Skalierungsstufe gesetzt

# Worker-Threads der Bildverarbeitung (Thumbnails, sharp/libvips).
#
# libvips startet per Default so viele Threads, wie CPU-Cores SICHTBAR sind -
# unabhaengig vom cgroup-CPU-Limit. Nachgemessen: sharp.concurrency() bleibt bei
# der Core-Zahl, auch mit --cpus=2.0. Auf einem 24-Core-Host waeren das 24
# Threads JE INSTANZ, bei 8 Instanzen also bis zu 192 Threads fuer 24 Cores.
# Das CPU-Limit drosselt sie dann per CFS-Quota, verhindert die Thread-Explosion
# aber nicht - es tauscht Ueberlast gegen Context-Switching.
#
# Sinnvoll ist derselbe Wert wie NOCODB_CPU_LIMIT: dann passt die Thread-Zahl
# zum verfuegbaren Quota und es entsteht kein Drosselungs-Overhead.
# VIPS_CONCURRENCY -> wird im Budget-Block oben je Skalierungsstufe gesetzt

# HAProxy. 3.4 ist das aktuelle LTS (Support bis 2031-Q2). Einen Tag
# "haproxy:3" gibt es nicht, und "haproxy:lts" wandert spaeter selbsttaetig auf
# 3.6/3.8 - zum Pinnen ungeeignet.
HAPROXY_VERSION=3.4

# maxconn je Server im WebSocket-Backend (/socket.io/).
# Bewusst getrennt vom API-Backend: In HTTP-Mode begrenzt maxconn gleichzeitige
# REQUESTS, und ein auf WebSocket hochgestufter Request haelt seinen Slot ueber
# die gesamte Verbindungsdauer. Mit einem gemeinsamen Backend haetten rund 80
# offene Browser-Tabs den kompletten Cluster belegt, ohne einen einzigen
# REST-Request - die Oberflaeche haette sich selbst ausgesperrt.
# WebSockets sind nicht DB-gebunden und ueberwiegend idle -> eigenes, deutlich
# groesseres Budget. 8 x 500 = 4000 gleichzeitige Sessions.
# HAPROXY_WS_MAXCONN -> wird im Budget-Block oben je Skalierungsstufe gesetzt

# HAProxy Stats-Seite. Nur ueber Loopback INNERHALB des Containers erreichbar:
#   docker exec -it <STACK>_LB wget -qO- http://127.0.0.1:8404/stats
# Aus dem Docker-Netz nicht erreichbar und niemals oeffentlich veroeffentlichen
# - die Seite legt Backend-Namen, IPs und Live-Verbindungszahlen offen.
HAPROXY_STATS_USER=admin
HAPROXY_STATS_PASSWORD=CHANGE_ME_STATS_PASSWORD

# Redis - ZWINGEND fuer den Mehr-Instanz-Betrieb.
# Ohne Redis cacht jede Instanz Metadaten lokal (Schemaaenderungen auf Instanz A
# werden auf B nicht sichtbar) und socket.io-Events bleiben auf der
# emittierenden Instanz. Beides faellt STILL aus - der Stack sieht dabei
# gesund aus.
REDIS_VERSION=8
# REDIS_MEMORYLIMIT -> wird im Budget-Block oben je Skalierungsstufe gesetzt

# BEWUSST noeviction, abweichend vom sonst ueblichen volatile-lru:
# Bull legt Jobs als Hash plus Referenzen in wait/active-Listen ab. Wird ein
# Job-Hash evictiert, bleiben tote Referenzen zurueck - Jobs verschwinden
# lautlos und die Queue kann blockieren. allkeys-lru waere hier fatal.
# noeviction laesst Schreibzugriffe stattdessen laut scheitern.
# Der NocoDB-Cache skaliert mit der SCHEMA-Groesse, nicht mit der Zeilenzahl -
# 2 GB werden im Normalbetrieb nie erreicht.
REDIS_MEMORYPOLICY=noeviction

# -----------------------------------------------------------------------------
# PostgreSQL Performance Tuning
# -----------------------------------------------------------------------------
# Alle Werte haben sinnvolle Standardwerte im Compose-File.
# Nur bei Bedarf anpassen und auskommentieren.
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ STORAGE I/O SETTINGS                                                        │
# │ (PostgreSQL: random_page_cost, effective_io_concurrency)                    │
# ├─────────────────────────────────┬───────────────────────────────────────────┤
# │ ENV Variable                    │ SSD/NVMe     │ HDD 10k    │ HDD 7.2k      │
# │                                 │ (default)    │ RPM        │ RPM           │
# ├─────────────────────────────────┼──────────────┼────────────┼───────────────┤
# │ PG_RANDOM_PAGE_COST             │ 1.1          │ 2.0        │ 4.0           │
# │ PG_EFFECTIVE_IO_CONCURRENCY     │ 200          │ 4          │ 2             │
# └─────────────────────────────────┴──────────────┴────────────┴───────────────┘
#
# PG_RANDOM_PAGE_COST=1.1
# PG_EFFECTIVE_IO_CONCURRENCY=200
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ MEMORY SETTINGS                                                             │
# │ (PostgreSQL: shared_buffers, effective_cache_size, work_mem,                │
# │              maintenance_work_mem)                                          │
# ├─────────────────────────────────┬───────────┬───────────┬─────────┬─────────┤
# │ ENV Variable                    │ 4 GB RAM  │ 8 GB RAM  │ 16 GB   │ 32 GB   │
# ├─────────────────────────────────┼───────────┼───────────┼─────────┼─────────┤
# │ PG_SHARED_BUFFERS               │ 1GB       │ 2GB       │ 4GB     │ 8GB     │
# │ PG_EFFECTIVE_CACHE_SIZE         │ 3GB       │ 6GB       │ 12GB    │ 24GB    │
# │ PG_WORK_MEM                     │ 4MB       │ 8MB       │ 16MB    │ 32MB    │
# │ PG_MAINTENANCE_WORK_MEM         │ 128MB     │ 256MB     │ 512MB   │ 1GB     │
# └─────────────────────────────────┴───────────┴───────────┴─────────┴─────────┘
#
# Hochlast-Profil (16 GB RAM, 1000+ parallele Inserts):
PG_SHARED_BUFFERS=4GB
PG_EFFECTIVE_CACHE_SIZE=12GB
PG_WORK_MEM=16MB
PG_MAINTENANCE_WORK_MEM=512MB
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ WAL SETTINGS (Write-Ahead Log)                                              │
# │ (PostgreSQL: max_wal_size, min_wal_size)                                    │
# ├─────────────────────────────────┬───────────┬───────────┬─────────┬─────────┤
# │ ENV Variable                    │ 4 GB RAM  │ 8 GB RAM  │ 16 GB   │ 32 GB   │
# ├─────────────────────────────────┼───────────┼───────────┼─────────┼─────────┤
# │ PG_MAX_WAL_SIZE                 │ 1GB       │ 2GB       │ 4GB     │ 8GB     │
# │ PG_MIN_WAL_SIZE                 │ 256MB     │ 512MB     │ 1GB     │ 2GB     │
# └─────────────────────────────────┴───────────┴───────────┴─────────┴─────────┘
#
# Hochlast-Profil (16 GB RAM, 1000+ parallele Inserts):
PG_MAX_WAL_SIZE=4GB
PG_MIN_WAL_SIZE=1GB

# -----------------------------------------------------------------------------
# Local Mode (docker-compose.local.yml)
# -----------------------------------------------------------------------------

# Direct port binding
# Examples: 8080, 192.168.1.100:8080, 127.0.0.1:8080
EXPOSED_APP_PORT=8080

# -----------------------------------------------------------------------------
# Traefik Configuration (all traefik compose files)
# -----------------------------------------------------------------------------

# Hostname - DNS must resolve to Traefik host
SERVICE_HOSTNAME=db.example.app.domain.com

# External Traefik network name
PROXY_NETWORK=EDGEPROXY

# -----------------------------------------------------------------------------
# Traefik Local Mode (docker-compose.traefik-local.yml)
# -----------------------------------------------------------------------------

# Allowed IP ranges (comma-separated CIDR notation)
# Common ranges:
#   127.0.0.1/32      - Localhost IPv4
#   ::1/128           - Localhost IPv6
#   192.168.0.0/16    - Private IPv4
#   10.0.0.0/8        - Private IPv4
#   fd00::/8          - Private IPv6 (ULA)
IP_WHITELIST=127.0.0.1/32,::1/128,192.168.0.0/16,fd88::/48

# -----------------------------------------------------------------------------
# Traefik Header Auth Mode (docker-compose.traefik-header-auth.yml)
# -----------------------------------------------------------------------------

# Secret for X-BAUERGROUP-Auth header
# Generate: uuidgen or openssl rand -hex 16
HEADER_AUTH_SECRET=00000000-0000-0000-0000-000000000000

# -----------------------------------------------------------------------------
# SMTP Configuration
# -----------------------------------------------------------------------------

# Die drei Werte SMTP_HOST, SMTP_PORT und SMTP_FROM sind eine Einheit: fehlt
# einer davon, ueberspringt NocoDB den kompletten SMTP-Block beim Start - auch
# SMTP_USER und SMTP_PASSWORD werden dann stillschweigend ignoriert.
#
# HINWEIS: Die SMTP-Einstellungen werden bei JEDEM Start aus diesen Variablen
# in die Datenbank geschrieben. Aenderungen, die in der NocoDB-UI vorgenommen
# werden, sind damit beim naechsten Neustart wieder ueberschrieben.

SMTP_HOST=smtp.example.com
SMTP_PORT=465

# Implizites TLS (SMTPS). true bei Port 465, false bei Port 587 (STARTTLS).
SMTP_TLS=true

# Zertifikatspruefung des SMTP-Servers -> NC_SMTP_REJECT_UNAUTHORIZED
# Nur auf false setzen, wenn der Server ein selbstsigniertes Zertifikat nutzt.
#
# ACHTUNG - fruehere Fehlkonfiguration: Bis einschliesslich v0.7.4 war
# SMTP_CERTCHECK auf NC_SMTP_IGNORE_TLS gemappt. Das ist eine voellig andere
# Einstellung (STARTTLS ueberspringen) - die Zertifikatspruefung war damit
# unabhaengig vom hier gesetzten Wert IMMER deaktiviert, weil
# NC_SMTP_REJECT_UNAUTHORIZED bei NocoDB per Default auf false steht.
SMTP_CERTCHECK=true

# STARTTLS-Aushandlung ueberspringen (NC_SMTP_IGNORE_TLS).
# Bei Port 465 ohne Wirkung, da dort bereits implizites TLS verwendet wird.
SMTP_IGNORE_TLS=false

SMTP_FROM_NAME=Database - Example
SMTP_FROM=no-reply@example.com
SMTP_USER=
SMTP_PASSWORD=

# -----------------------------------------------------------------------------
# NocoDB Application Settings
# -----------------------------------------------------------------------------

# Attachment size limit in bytes (default: 256 MB = 268435456)
# NC_ATTACHMENT_FIELD_SIZE=268435456

# Maximum attachments per field (default: 50)
# NC_MAX_ATTACHMENTS_ALLOWED=50

# Non-attachment field size in bytes (default: 256 MB = 268435456)
# Maximale Groesse fuer Nicht-Attachment-Felder in Multipart-Uploads.
# NC_NON_ATTACHMENT_FIELD_SIZE=268435456

# Secure attachments (pre-signed URLs only)
# NC_SECURE_ATTACHMENTS=false
# NC_ATTACHMENT_EXPIRE_SECONDS=7200

# Query & Bulk Operation Limits
# NocoDB hat beide Limits stillschweigend auf 100 reduziert.
#
# Query-Limit: Maximale Records pro GET-Request (Pagination).
# Werte ueber DB_QUERY_LIMIT_MAX werden ignoriert und auf 100 gekuerzt.
# DB_QUERY_LIMIT_DEFAULT=25
# DB_QUERY_LIMIT_MAX=1000
# DB_QUERY_LIMIT_MIN=1
# DB_QUERY_LIMIT_GROUP_BY_GROUP=10
# DB_QUERY_LIMIT_GROUP_BY_RECORD=10
#
# Bulk-Limit: Maximale Entities pro POST/PATCH/DELETE Bulk-Request.
# Betrifft nur API-Token-Authentifizierung (nicht Session-Login).
# Fehler bei Ueberschreitung: ERR_MAX_PAYLOAD_LIMIT_EXCEEDED
# NC_DATA_PAYLOAD_LIMIT=100000
#
# Request Body Size in bytes (default: 256 MB = 268435456)
# Maximale Groesse des gesamten Request-Body (JSON/Form-Daten).
# NC_REQUEST_BODY_SIZE=268435456

# Hinweis: API Rate Limits sind nicht via .env konfigurierbar.
# Sie sind in den Compose-Files fest verdrahtet (Data 5000/sec, Meta 120/min,
# kein Block) - API-Zugriff ist Token-gated, deshalb braucht es keinen
# Per-Instance-Override.

# -----------------------------------------------------------------------------
# S3/MinIO Storage (optional)
# -----------------------------------------------------------------------------

# Uncomment to enable S3-compatible storage for attachments
# NC_S3_BUCKET_NAME=nocodb-bucket
# NC_S3_REGION=us-east-1
# NC_S3_ENDPOINT=https://s3.example.com
# NC_S3_ACCESS_KEY=
# NC_S3_ACCESS_SECRET=
# NC_S3_FORCE_PATH_STYLE=true
# NC_S3_ACL=private

# -----------------------------------------------------------------------------
# NocoDB Init Container
# -----------------------------------------------------------------------------
# One-shot container that runs database maintenance tasks before NocoDB starts.
# Tasks can be enabled/disabled individually.

# Collation Version Check (default: true)
# Checks for PostgreSQL collation version mismatches after OS/libc updates.
# Mismatches can cause index corruption if not addressed.
# INIT_COLLATION_CHECK=true

# Collation Auto-Fix (default: false)
# WARNING: When enabled, automatically runs REINDEX DATABASE CONCURRENTLY
# to fix collation mismatches. Requires PostgreSQL 12+.
# Only enable if you understand the implications.
# INIT_COLLATION_AUTO_FIX=false

# Audit Cleanup (default: true)
# Cleans up audit and log tables (nc_audit_v2, nc_hook_logs_v2, etc.)
# on container start when NC_DISABLE_AUDIT=true is set.
# Removes historical data that is no longer needed.
# INIT_AUDIT_CLEANUP=true

# -----------------------------------------------------------------------------
# NocoDB Backup Sidecar (Optional)
# -----------------------------------------------------------------------------
# Automated backup service for NocoDB with S3 support.
#
# Activate per command:
#   docker compose -f <compose-file> --profile backup up -d
#
# Activate permanently (via Docker Compose's built-in COMPOSE_PROFILES variable):
#   Set COMPOSE_PROFILES=backup below. Then `docker compose up -d` alone
#   will start the backup sidecar. Use comma-separated values for multiple
#   profiles (e.g. COMPOSE_PROFILES=backup,minio in development).
#   To temporarily disable: set COMPOSE_PROFILES= (empty) or remove the line.
#
# Backup Methods:
#   1. Database Dump (pg_dump) - Full PostgreSQL backup for disaster recovery
#   2. NocoDB Data Files (tar.gz) - 1:1 archive of uploads/attachments
#   3. NocoDB API Export - Bases, tables, records, and attachments as JSON

# Docker Compose profiles that should be active by default.
# Empty/unset = no additional profiles. Set to "backup" to always run the
# backup sidecar without having to pass --profile backup on every up command.
# COMPOSE_PROFILES=backup

# ─── NocoDB API Access ───
# Required for API-based backups (bases, tables, records, attachments)
# Generate token in NocoDB: Account Settings > Tokens > Add new token
NOCODB_API_TOKEN=

# NOTE: the backup sidecar now runs on the central BackupHelper engine
# (ghcr.io/bauer-group/cs-backuphelper) via BACKUP_CONFIG_JSON in the compose.
# The variables below feed that config; the engine also reads NOCODB_API_URL
# and NOCODB_API_TOKEN directly for the `nocodb restore-*` commands.

# ─── NocoDB REST endpoint (for the restore commands) ───
# NOCODB_API_URL=http://nocodb-server:8080

# ─── Instance Identification ───
# Used in alerts and backup organization
# NOCODB_BACKUP_INSTANCE_NAME=nocodb

# ─── Backup Schedule ───
# The container runs the scheduler daemon whenever the "backup" profile is up;
# to disable scheduled backups, simply do not enable that profile.
# Schedule mode: "cron" (specific time) or "interval" (every N hours)
# NOCODB_BACKUP_SCHEDULE_MODE=cron

# Cron mode settings (default: 05:15 daily)
# NOCODB_BACKUP_SCHEDULE_HOUR=5
# NOCODB_BACKUP_SCHEDULE_MINUTE=15
# NOCODB_BACKUP_SCHEDULE_DAY_OF_WEEK=*

# Interval mode settings
# NOCODB_BACKUP_SCHEDULE_INTERVAL_HOURS=24

# Run one backup immediately on container start
# NOCODB_BACKUP_ON_STARTUP=false

# ─── Backup Configuration ───
# Retention: Number of backups to keep (<= 0 keeps EVERYTHING)
# NOCODB_BACKUP_RETENTION_COUNT=30

# Database Dump (pg_dump, plain SQL -> database.sql.gz). Set "false" to skip.
# NOCODB_BACKUP_DATABASE_DUMP=true
# NOCODB_BACKUP_DATABASE_DUMP_TIMEOUT=1800

# NocoDB API Export (REST: bases/tables/records/attachments). Set "false" to skip.
# NOCODB_BACKUP_API_EXPORT=true
# NOCODB_BACKUP_INCLUDE_RECORDS=true

# Attachment-Download im API-Export
# Auf "false" setzen wenn Attachments bereits auf S3 liegen (NC_S3_BUCKET_NAME),
# da diese dort separat gesichert werden koennen.
# NOCODB_BACKUP_INCLUDE_ATTACHMENTS=true

# NocoDB Daten-Dateien (Uploads/Attachments) als tar.gz sichern
# Erstellt ein 1:1 Archiv des NocoDB-Datenverzeichnisses.
# für vollstaendige Disaster Recovery. Set "false" to skip.
# NOCODB_BACKUP_INCLUDE_FILES=true

# Keep the local archive after a successful off-site S3 upload.
# (Replaces the old NOCODB_BACKUP_DELETE_LOCAL_AFTER_S3 toggle, inverted.)
# NOCODB_BACKUP_KEEP_LOCAL_ARCHIVE=true

# ─── S3 Storage (Backup Target) ───
# Configure to upload backups to S3-compatible storage.
# S3 is used when a bucket is set; otherwise the backup stays local only.
# NOCODB_BACKUP_S3_ENDPOINT_URL=
# NOCODB_BACKUP_S3_BUCKET=
# NOCODB_BACKUP_S3_ACCESS_KEY=
# NOCODB_BACKUP_S3_SECRET_KEY=
# NOCODB_BACKUP_S3_REGION=eu-north-1
# NOCODB_BACKUP_S3_PREFIX=nocodb/

# ─── Alerting ───
# Get notified about backup success/failure. Leave the channels list empty to
# disable alerting entirely.
# NOCODB_BACKUP_ALERT_LEVEL=warnings
# NOCODB_BACKUP_ALERT_CHANNELS=email,teams,webhook

# Email alerts (requires SMTP configuration above)
# NOCODB_BACKUP_ALERT_EMAIL=admin@example.com

# Microsoft Teams webhook
# NOCODB_BACKUP_TEAMS_WEBHOOK=https://outlook.office.com/webhook/...

# Generic webhook (POST with JSON payload; HMAC-SHA256 signed if a secret is set)
# NOCODB_BACKUP_WEBHOOK_URL=https://your-webhook.example.com/backup
# NOCODB_BACKUP_WEBHOOK_SECRET=

# ─── Logging ───
# Log level: DEBUG, INFO, WARNING, ERROR
# NOCODB_BACKUP_LOG_LEVEL=INFO
# NOCODB_BACKUP_LOG_FORMAT=console   # console | json

# -----------------------------------------------------------------------------
# MinIO Development (docker-compose.development.yml only)
# -----------------------------------------------------------------------------
# Local S3-compatible storage for development and testing.
# Console: http://localhost:9001
# API:     http://localhost:9000

# MinIO root credentials (admin access)
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin

# MinIO ports
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001

# =============================================================================
# Deployment
# =============================================================================
#
# Local Mode (direct port access):
#   docker compose -f docker-compose.local.yml up -d
#   Access: http://localhost:${EXPOSED_APP_PORT}
#
# Traefik HTTPS (production):
#   docker compose -f docker-compose.traefik.yml up -d
#   Access: https://${SERVICE_HOSTNAME}
#
# Traefik HTTP + IP-Whitelist (internal network):
#   docker compose -f docker-compose.traefik-local.yml up -d
#   Access: http://${SERVICE_HOSTNAME}
#
# Traefik HTTPS + Header Auth (protected):
#   docker compose -f docker-compose.traefik-header-auth.yml up -d
#   Access: https://${SERVICE_HOSTNAME}
#   Header: X-BAUERGROUP-Auth: ${HEADER_AUTH_SECRET}
#
# =============================================================================
# PostgreSQL Upgrade Notes
# =============================================================================
#
# For upgrading PostgreSQL (e.g., 15 to 18):
#   See pg_upgrade_inplace.sh in Shared/Scripts folder
#
# =============================================================================
